# ===== Banco de Dados (PostgreSQL) =====
# Usado pelo docker-compose.yml e pelo backend (python_core/database.py)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=mandaca
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# ===== Redis =====
# Cache e buffer de mensagens do bot (python_core/redis_cache.py)
REDIS_HOST=localhost
REDIS_PORT=6379

# Tempo (em segundos) que o bot espera juntando mensagens antes de processar
MESSAGE_BUFFER_SECONDS=20

# ===== Bot WhatsApp =====
# URL do webhook da API que o bot vai chamar (python_core/whatsapp_bot.py)
API_URL=http://localhost:8000/webhook

# JID do grupo de WhatsApp (opcional). Deixe vazio para desabilitar.
# Exemplo: 1234567890-1234567890@g.us
GRUPO_WHATSAPP=

# ===== Gemini (IA) =====
# Liga/desliga a integração com Gemini (true/false)
GEMINI_ENABLED=false

# Chave da API Gemini (obtenha em https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=sua_chave_gemini_aqui

# ===== Autenticação (JWT) =====
# Chave secreta usada para assinar os tokens. EM PRODUÇÃO, gere algo aleatório
# longo (ex: `openssl rand -hex 32`) e NUNCA exponha.
JWT_SECRET=troque-isso-em-producao-use-uma-string-aleatoria-longa

# Tempo de expiração do token (em horas). 168h = 7 dias.
JWT_EXPIRATION_HOURS=168
