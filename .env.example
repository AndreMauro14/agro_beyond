# ===== Banco de Dados (PostgreSQL) =====
# Em produção (Neon, etc.) defina DATABASE_URL e o backend ignora as variáveis abaixo.
# Em dev local com docker-compose, deixe DATABASE_URL vazio e use DB_HOST/DB_PORT/...
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5433
DB_NAME=mandaca
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# ===== Redis =====
# Em produção (Upstash) defina REDIS_URL (formato rediss://default:senha@host:porta).
# Em dev local, deixe REDIS_URL vazio e use REDIS_HOST/REDIS_PORT.
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379

# Tempo (em segundos) que o bot espera juntando mensagens antes de processar
MESSAGE_BUFFER_SECONDS=20

# ===== Bot WhatsApp =====
# URL do webhook da API que o bot vai chamar (python_core/whatsapp_bot.py)
API_URL=http://localhost:8000/webhook

# JID do grupo de WhatsApp (opcional). Deixe vazio para desabilitar.
# Exemplo: 1234567890-1234567890@g.us
GRUPO_WHATSAPP=

# ===== Gemini (IA) =====
# Liga/desliga a integração com Gemini (true/false)
GEMINI_ENABLED=false

# Chave da API Gemini (obtenha em https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=sua_chave_gemini_aqui

# ===== Autenticação (JWT) =====
# Chave secreta usada para assinar os tokens. EM PRODUÇÃO, gere algo aleatório
# longo (ex: `openssl rand -hex 32`) e NUNCA exponha.
JWT_SECRET=troque-isso-em-producao-use-uma-string-aleatoria-longa

# Tempo de expiração do token (em horas). 168h = 7 dias.
JWT_EXPIRATION_HOURS=168

# ===== CORS =====
# Origens permitidas para chamar a API, separadas por vírgula.
# Em produção: https://agro-beyond.vercel.app
# Em dev local: deixe vazio (libera tudo, "*").
CORS_ORIGINS=
